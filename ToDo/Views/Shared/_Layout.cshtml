<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Tasks</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ToDo.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        .pagination .page-item.active .page-link {
            color: grey; 
            background-color: white;
            border-color: grey;
        }

        .pagination .page-item .page-link {
            color: grey;
        }
    </style>
</head>

<body>
    
    <div class="container">
        <header class="">
            <nav class="navbar navbar-dark bg-dark shadow-sm mb-4">
                <div class="container-fluid">
                    <span class="navbar-brand fw-semibold">
                        Task Management System
                    </span>
                </div>
            </nav>
        </header>
        <main>
            @RenderBody()
        </main>
    </div>
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="appToast" class="toast align-items-center text-white bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastMessage">
                    <!-- message here -->
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    Are you sure you want to delete this task?
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                        Delete
                    </button>
                </div>

            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const message = '@TempData["ToastMessage"]';
            const type = '@TempData["ToastType"]';

            if (message) {
                showToast(message, type === "error");
            }
        });

        function showToast(message, isError = false) {
            const toastEl = document.getElementById('appToast');
            const toastMsg = document.getElementById('toastMessage');

            toastMsg.innerText = message;

            // Change color dynamically
            toastEl.classList.remove('bg-success', 'bg-danger');
            toastEl.classList.add(isError ? 'bg-danger' : 'bg-success');

            const toast = new bootstrap.Toast(toastEl);
            toast.show();
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
