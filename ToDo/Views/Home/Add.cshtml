@using ToDoDemo.ViewModels
@model AddViewModel

<h2>@(Model.ToDo.Id == 0 ? "New Task" : "Edit Task")</h2>

<div asp-validation-summary="All" class="text-danger"></div>
<form asp-action=@(Model.ToDo.Id == 0 ? "AddTask" : "Edit") method="post">
    <input type="hidden" asp-for="ToDo.Id" />
    <div class="mb-3">
        <label asp-for="ToDo.Description" class="form-label">Description</label>
        <input asp-for="ToDo.Description" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="ToDo.CategoryId" class="form-label">Category</label>
        <select asp-for="ToDo.CategoryId" class="form-select" asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name"))">
            <option value=""></option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="ToDo.DueDate" class="form-label">Due Date</label>
        <input asp-for="ToDo.DueDate" class="form-control" type="text" />
    </div>
    <div class="mb-3">
        <label asp-for="ToDo.StatusId" class="form-label">Status</label>
        <select asp-for="ToDo.StatusId" class="form-select" asp-items="@(new SelectList(Model.Statuses, "StatusId", "Name"))">
            <option value=""></option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="ToDo.Priority" class="form-label">Priority</label>
        <select asp-for="ToDo.Priority"
                class="form-select"
                asp-items="@(new SelectList(Model.Priorities))">
        </select>
    </div>
    <button type="submit" class="btn btn-primary">@(Model.ToDo.Id == 0 ? "Add Task" : "Update Task")</button>
    <a asp-action="Index" class="btn btn-primary">Cancel</a>
</form>