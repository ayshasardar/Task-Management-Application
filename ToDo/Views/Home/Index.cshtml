<script>
    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".mark-complete-btn").forEach(btn => {
            btn.addEventListener("click", function (e) {
                //Role of e.stopPropagation() => Button click → stopPropagation() → event DOES NOT reach row
                e.stopPropagation();
                const taskId = this.getAttribute("data-id");
                const row = this.closest("tr");
                debugger;
                fetch(`/api/tasks/complete/${taskId}`, {
                    method: "POST"
                })
                  .then(response => response.json())
                .then(data => {
                    const row = this.closest("tr");

                    // Update status text
                    const statusCell = row.querySelector(".status-cell");
                    if (statusCell) {
                        statusCell.innerText = "Completed";
                    }

                    //Remove the button (same effect as Razor)
                    this.remove();
                    showToast("Task marked as completed");
                })
                .catch(err => {
                showToast("Something went wrong", true);
                });
            });
        });

        document.querySelectorAll(".task-row").forEach(row => {
            row.addEventListener("click", function (e) {

                // prevent click from buttons (delete / complete)
                if (e.target.closest("button")) return;

                const id = this.getAttribute("data-id");
                window.location.href = `/Home/Edit/${id}`;
            });
        });


        let selectedForm = null;

        // Open modal
        document.querySelectorAll(".delete-btn").forEach(btn => {
            btn.addEventListener("click", function () {
                selectedForm = this.closest("form");

                const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
                modal.show();
            });
        });

        // Confirm delete
        document.getElementById("confirmDeleteBtn")
            .addEventListener("click", function () {

                if (selectedForm) {
                    selectedForm.submit();
                }
            });

    });
</script>