    <div class="col-md-9">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">
                Tasks
            </div>
            <div class="card-body">
                @*  *@
                @*                 <form asp-controller="Home" asp-action="MarkComplete" method="post" asp-route-id="@Model.Filters.FilterString">
 *@                    <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th>Category</th>
                            <th>Due Date</th>
                            @* <th>
                                    <a asp-action="Index"
                                       asp-route-sortVm.SortBy="duedate"
                                       asp-route-sortVm.Direction="@Model.SortVm.ToggleDirection"
                                       asp-route-page="@Model.CurrentPage"
                                       asp-route-FilterVm.Category="@Model.FilterVm.Category"
                                       asp-route-FilterVm.Due="@Model.FilterVm.Due"
                                       asp-route-FilterVm.Status="@Model.FilterVm.Status"
                                       class="text-decoration-none text-dark">
                                        Due Date
                                    </a>
                                </th> *@

                            <th>Status</th>
                            <th>Priority</th>
                            <th></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ToDo task in Model.ToDos)
                        {
                            string overdue = task.Overdue ? "table-warning" : "";
                            @* <tr> old tr*@
                            @* make table row clickable to edit a record *@
                            <tr class="task-row" data-id="@task.Id" style="cursor:pointer;">
                                <td>@task.Description</td>
                                <td>@task.Category.Name</td>
                                <td class="text-muted">@task.DueDate?.ToShortDateString()</td>
                                <td class="@overdue status-cell">@task.Status.Name</td>
                                <td>
                                    <span class="badge @(task.Priority == PriorityLevel.High ? "bg-danger" : task.Priority == PriorityLevel.Medium ? "bg-warning" : "bg-secondary")">
                                        @task.Priority
                                    </span>
                                </td>
                                <td>
                                    @if (task.StatusId == "open")
                                    {
                                        @*When we use fetch(), the browser does NOT submit a form, so the MVC action is not triggered at all.  
                                                page reload only occurs if i have btn type submit
                                            <button type = "submit" class="btn btn-outline-success btn-sm mark-complete-btn"
                                                    name="@nameof(ToDo.Id)" value="@task.Id" title="Mark Completed">
                                                <i class="bi-solid bi-check-circle"></i>
                                            </button> *@
                                        <button type="button" title="Mark Complete"
                                                class="btn btn-outline-success btn-sm mark-complete-btn"
                                                data-id="@task.Id">
                                            <i class="bi-solid bi-check-circle"></i>
                                        </button>

                                    }
                                </td>

                                <td>
                                    <form asp-action="Delete"
                                          asp-route-id="@Model.Filters.FilterString"
                                          method="post"
                                          class="delete-form">
                                        <input type="hidden" name="Id" value="@task.Id" />

                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger delete-btn"
                                                title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>


                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @* previous and next btns are not working in nav bar - will work on it later *@
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Page navigation example" style="color:black;">
                        <ul class="pagination">
                            @* <li class="page-item">
                                    <a class="page-link" href="#" aria-label="Previous">
                                        <span aria-hidden="true">&laquo;</span>
                                        <span class="sr-only">Previous</span>
                                    </a>
                                </li> *@
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {

                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-FilterVm.SortBy="@Model.FilterVm.SortBy"
                                       asp-route-FilterVm.Category="@Model.FilterVm.Category"
                                       asp-route-FilterVm.Due="@Model.FilterVm.Due"
                                       asp-route-FilterVm.Status="@Model.FilterVm.Status">
                                        @i
                                    </a>
                                </li>

                            }
                            @*  <li class="page-item">
                                    <a class="page-link" href="#" aria-label="Next">
                                        <span aria-hidden="true">&raquo;</span>
                                        <span class="sr-only">Next</span>
                                    </a>
                                </li> *@
                        </ul>
                    </nav>
                }

                @*  </form> *@
                <form asp-action="DeleteComplete" method="post" asp-route-id="@Model.Filters.FilterString">
                    <a asp-action="Add" class="btn btn-success">Add New Task</a>
                    <button type="submit" class="btn btn-danger">Delete Completed Task</button>
                    <a asp-controller="Categories" asp-action="Add"
                       class="btn btn-outline-info">
                        + Add New Category
                    </a>
